{
	"$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
	"appId": "waypaper.engine",
	"asar": false,
	"npmRebuild": true,
	"directories": {
		"output": "release"
	},
	"files": ["dist-electron", "dist"],
	"extraFiles": [
		{
			"from": "build/icons/",
			"to": "resources/icons/",
			"filter": ["**/*"]
		},
		{
			"from": "daemon/build/waypaper-daemon",
			"to": "resources/waypaper-daemon"
		}
	],
	"linux": {
		"artifactName": "${productName}.${ext}",
		"category": "Utility",
		"target": ["dir"],
		"executableName": "waypaper-engine-bin",
		"description": "A graphical frontend for setting wallpapers and playlists, using awww under the hood!",
		"desktop": {
			"entry": {
				"Name": "Waypaper Engine",
				"Comment": "Waypaper Engine",
				"Terminal": "false",
				"Type": "Application",
				"Icon": "/build/icons/512x512.png"
			}
		}
	}
}
