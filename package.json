{
	"name": "waypaper-engine",
	"private": true,
	"version": "2.0.4",
	"author": {
		"name": "0bCdian",
		"email": "diegoparranava@protonmail.com",
		"url": "https://github.com/0bCdian"
	},
	"scripts": {
		"dev": "npm run build:daemon && DEV=true vite",
		"rebuild": "electron-rebuild",
		"build:daemon": "cd daemon && go build -o waypaper-daemon ./cmd/daemon",
		"build": "npm run build:daemon && npm install && npm run rebuild && vite build && electron-builder",
		"lint": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ --fix",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test:daemon": "cd daemon && go test ./... -v",
		"test:daemon:unit": "cd daemon && go test -short ./... -v",
		"test:daemon:integration": "cd daemon && go test ./test/... -v",
		"test:daemon:benchmark": "cd daemon && go test -bench=. -benchmem ./...",
		"test:daemon:coverage": "cd daemon && go test -coverprofile=coverage.out ./... && go tool cover -html=coverage.out -o coverage.html",
		"test:daemon:race": "cd daemon && go test -race ./... -v",
		"test:daemon:build": "cd daemon && go build ./cmd/daemon",
		"test:daemon:clean": "cd daemon && rm -f waypaper-daemon coverage.out coverage.html"
	},
	"dependencies": {
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/sortable": "7.0.2",
		"framer-motion": "10.13.1",
		"pino": "9.13.1",
		"react": "18.3.1",
		"react-bezier-curve-editor": "1.1.2",
		"react-dom": "18.3.1",
		"react-hook-form": "7.53.0",
		"react-hotkeys-hook": "4.5.0",
		"react-responsive-pagination": "2.9.0",
		"react-router-dom": "6.15.0",
		"zustand": "4.5.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.6",
		"@electron/rebuild": "3.6.0",
		"@tailwindcss/postcss": "4.1.14",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "22.13.0",
		"@types/react": "18.3.12",
		"@types/react-dom": "18.3.1",
		"@vitejs/plugin-react": "5.0.0",
		"daisyui": "^5.2.3",
		"electron": "38.2.1",
		"electron-builder": "25.1.8",
		"electron-reload": "2.0.0-alpha.1",
		"oxlint": "1.19.0",
		"tailwindcss": "^4.1.14",
		"typescript": "5.5.4",
		"vite": "6.3.6",
		"vite-plugin-electron": "0.28.8",
		"vite-plugin-electron-renderer": "0.14.6"
	},
	"main": "dist-electron/main.js",
	"homepage": "./"
}
