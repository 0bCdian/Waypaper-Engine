{
  "name": "waypaper-engine",
  "private": true,
  "version": "3.0.0",
  "packageManager": "pnpm@9.15.9",
  "description": "A wallpaper setter GUI with playlist functionality for Wayland and X11",
  "author": {
    "name": "0bCdian",
    "email": "diegoparranava@protonmail.com",
    "url": "https://github.com/0bCdian"
  },
  "scripts": {
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "generate:openapi": "cd daemon && go generate ./cmd/daemon/",
    "ci:openapi": "cd daemon && swag init -g cmd/daemon/main.go -o docs --outputTypes yaml --parseInternal --parseDependency && git diff --exit-code -- daemon/docs/swagger.yaml && git ls-files --error-unmatch daemon/docs/swagger.yaml",
    "generate:types": "openapi-typescript daemon/docs/openapi.yaml -o electron/daemon-go-types.generated.ts && pnpm exec oxfmt electron/daemon-go-types.generated.ts",
    "ci:types": "pnpm run generate:types && git diff --exit-code -- electron/daemon-go-types.generated.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev": "pnpm run build:daemon && DEV=true vite",
    "build:daemon": "make daemon && pnpm run generate:types",
    "build": "pnpm run build:daemon && vite build && electron-builder --publish never --config electron-builder.json --linux dir",
    "ci:check": "pnpm run build:daemon && pnpm run format:check && pnpm run lint:check && pnpm run gofmt:check && pnpm exec tsc --noEmit && pnpm run test && pnpm run test:daemon:unit && pnpm exec vite build",
    "postinstall": "electron-builder install-app-deps",
    "lint": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ shared/ electron/ globals/ --fix",
    "lint:check": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ shared/ electron/ globals/",
    "format": "oxfmt \"src/**/*.{ts,tsx,css}\" \"shared/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"globals/**/*.ts\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx,css}\" \"shared/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"globals/**/*.ts\"",
    "gofmt:check": "bash -c 'out=$(gofmt -l daemon); if [ -n \"$out\" ]; then echo \"$out\"; exit 1; fi'",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:daemon": "cd daemon && go test ./... -v",
    "test:daemon:unit": "cd daemon && go test -short ./... -v",
    "test:daemon:integration": "cd daemon && go test ./test/... -v",
    "test:daemon:benchmark": "cd daemon && go test -bench=. -benchmem ./...",
    "test:daemon:coverage": "cd daemon && go test -coverprofile=coverage.out ./... && go tool cover -html=coverage.out -o coverage.html",
    "test:daemon:race": "cd daemon && go test -race ./... -v",
    "test:daemon:build": "cd daemon && go build ./cmd/daemon",
    "test:daemon:clean": "cd daemon && rm -rf build coverage.out coverage.html",
    "test:e2e": "pnpm run build:daemon && pnpm exec playwright test --config e2e/playwright.config.ts",
    "test:ui": "pnpm exec playwright test --config e2e/playwright-ui.config.ts",
    "test:all": "pnpm run test && pnpm run test:daemon && pnpm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/abstract": "0.3.2",
    "@dnd-kit/dom": "0.3.2",
    "@dnd-kit/helpers": "0.3.2",
    "@dnd-kit/react": "0.3.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/aldrich": "5.2.7",
    "@fontsource/google-sans": "^5.2.1",
    "@fontsource/google-sans-flex": "^5.2.4",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-form": "^1.28.3",
    "ci": "^2.3.0",
    "framer-motion": "12.34.0",
    "pino": "9.13.1",
    "pino-roll": "^4.0.0",
    "react": "^19.2.4",
    "react-colorful": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "4.5.0",
    "react-responsive-pagination": "2.13.0",
    "react-router-dom": "6.30.3",
    "react-select": "^5.10.2",
    "toml": "3.0.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "culori": "^4.0.2",
    "daisyui": "5.2.3",
    "electron": "40.4.1",
    "electron-builder": "26.8.1",
    "electron-reload": "2.0.0-alpha.1",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.35.0",
    "oxlint": "1.19.0",
    "tailwindcss": "4.1.14",
    "typescript": "5.5.4",
    "vite": "^6.4.1",
    "vite-plugin-electron": "0.28.8",
    "vite-plugin-electron-renderer": "0.14.6",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.3"
  },
  "main": "dist-electron/main.js",
  "homepage": "./"
}
