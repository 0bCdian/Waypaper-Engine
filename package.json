{
	"name": "waypaper-engine",
	"private": true,
	"version": "3.0.0",
	"description": "A wallpaper setter GUI with playlist functionality for Wayland and X11",
	"author": {
		"name": "0bCdian",
		"email": "diegoparranava@protonmail.com",
		"url": "https://github.com/0bCdian"
	},
	"scripts": {
		"dev": "npm run build:daemon && DEV=true vite",
		"build:daemon": "mkdir -p daemon/build && cd daemon && go build -ldflags \"-s -w\" -o build/waypaper-daemon ./cmd/daemon",
		"build": "npm run build:daemon && vite build && electron-builder --publish never --config electron-builder.json",
		"postinstall": "electron-builder install-app-deps",
		"lint": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ --fix",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:daemon": "cd daemon && go test ./... -v",
		"test:daemon:unit": "cd daemon && go test -short ./... -v",
		"test:daemon:integration": "cd daemon && go test ./test/... -v",
		"test:daemon:benchmark": "cd daemon && go test -bench=. -benchmem ./...",
		"test:daemon:coverage": "cd daemon && go test -coverprofile=coverage.out ./... && go tool cover -html=coverage.out -o coverage.html",
		"test:daemon:race": "cd daemon && go test -race ./... -v",
		"test:daemon:build": "cd daemon && go build ./cmd/daemon",
		"test:daemon:clean": "cd daemon && rm -rf build coverage.out coverage.html",
		"test:e2e": "npm run build:daemon && npx playwright test --config e2e/playwright.config.ts",
		"test:ui": "npx playwright test --config e2e/playwright-ui.config.ts",
		"test:all": "npm run test && npm run test:daemon && npm run test:e2e"
	},
	"dependencies": {
		"@dnd-kit/helpers": "0.3.2",
		"@dnd-kit/react": "0.3.2",
		"@fontsource-variable/sora": "5.2.8",
		"@fontsource/google-sans": "5.2.1",
		"@fontsource/google-sans-flex": "5.2.2",
		"@tanstack/react-form": "^1.28.3",
		"framer-motion": "12.34.0",
		"pino": "9.13.1",
		"pino-roll": "^4.0.0",
		"react": "^19.2.4",
		"react-bezier-curve-editor": "1.1.2",
		"react-dom": "^19.2.4",
		"react-hotkeys-hook": "4.5.0",
		"react-responsive-pagination": "2.13.0",
		"react-router-dom": "6.30.3",
		"smol-toml": "1.6.0",
		"toml": "3.0.0",
		"zustand": "5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.6",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "4.1.14",
		"@tailwindcss/vite": "4.1.14",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "22.13.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "5.0.0",
		"@vitest/coverage-v8": "^4.0.18",
		"babel-plugin-react-compiler": "^1.0.0",
		"daisyui": "5.2.3",
		"electron": "40.4.1",
		"electron-builder": "26.8.1",
		"electron-reload": "2.0.0-alpha.1",
		"jsdom": "^28.1.0",
		"oxlint": "1.19.0",
		"tailwindcss": "4.1.14",
		"typescript": "5.5.4",
		"vite": "^6.4.1",
		"vite-plugin-electron": "0.28.8",
		"vite-plugin-electron-renderer": "0.14.6",
		"vitest": "^4.0.18"
	},
	"main": "dist-electron/main.js",
	"homepage": "./"
}
