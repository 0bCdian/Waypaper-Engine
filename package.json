{
	"name": "waypaper-engine",
	"private": true,
	"version": "2.0.4",
	"author": {
		"name": "0bCdian",
		"email": "diegoparranava@protonmail.com",
		"url": "https://github.com/0bCdian"
	},
	"scripts": {
		"dev": "npm run build_go_daemon && DEV=true vite",
		"rebuild": "electron-rebuild",
		"build_go_daemon": "cd daemon-go && go build -o waypaper-daemon ./cmd/daemon",
		"build": "npm run build_go_daemon && npm install && npm run rebuild && vite build && electron-builder",
		"lint": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ --fix",
		"format": "oxlint --react-plugin --tsconfig ./tsconfig.json src/ --fix",
		"preview": "vite preview",
		"test:daemon": "cd daemon-go && go test ./... -v",
		"test:daemon:unit": "cd daemon-go && go test -short ./... -v",
		"test:daemon:integration": "cd daemon-go && go test ./test/... -v",
		"test:daemon:benchmark": "cd daemon-go && go test -bench=. -benchmem ./...",
		"test:daemon:coverage": "cd daemon-go && go test -coverprofile=coverage.out ./... && go tool cover -html=coverage.out -o coverage.html",
		"test:daemon:race": "cd daemon-go && go test -race ./... -v",
		"test:daemon:build": "cd daemon-go && go build ./cmd/daemon && go build ./cmd/cli",
		"test:daemon:clean": "cd daemon-go && rm -f waypaper-daemon waypaper-engine-cli coverage.out coverage.html test.db test.db-shm test.db-wal",
		"test:daemon:suite": "./test-daemon.sh",
		"test:daemon:suite:unit": "./test-daemon.sh unit",
		"test:daemon:suite:integration": "./test-daemon.sh integration",
		"test:daemon:suite:benchmark": "./test-daemon.sh benchmark",
		"test:daemon:suite:coverage": "./test-daemon.sh coverage",
		"test:daemon:suite:race": "./test-daemon.sh race",
		"test:daemon:suite:build": "./test-daemon.sh build",
		"test:daemon:suite:clean": "./test-daemon.sh clean"
	},
	"dependencies": {
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/modifiers": "6.0.1",
		"@dnd-kit/sortable": "7.0.2",
		"@dnd-kit/utilities": "3.2.2",
		"@types/pino": "^7.0.4",
		"chokidar": "4.0.1",
		"esbuild": "^0.25.10",
		"framer-motion": "10.13.1",
		"pino": "9.13.1",
		"react": "18.3.1",
		"react-bezier-curve-editor": "1.1.2",
		"react-dom": "18.3.1",
		"react-error-boundary": "^6.0.0",
		"react-hook-form": "7.53.0",
		"react-hotkeys-hook": "4.5.0",
		"react-responsive-pagination": "2.9.0",
		"react-router-dom": "6.15.0",
		"smol-toml": "1.4.2",
		"theme-change": "^2.5.0",
		"toml": "3.0.0",
		"zustand": "4.5.5"
	},
	"devDependencies": {
		"@electron/rebuild": "3.6.0",
		"@tailwindcss/postcss": "^4.1.14",
		"@types/node": "22.13.0",
		"@types/react": "18.3.12",
		"@types/react-dom": "18.3.1",
		"@vitejs/plugin-react": "5.0.0",
		"autoprefixer": "10.4.14",
		"daisyui": "^5.2.3",
		"electron": "38.2.1",
		"electron-builder": "25.1.8",
		"electron-reload": "^2.0.0-alpha.1",
		"oxlint": "^1.19.0",
		"postcss": "8.4.41",
		"prettier": "3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"tailwindcss": "^4.1.14",
		"typescript": "5.5.4",
		"vite": "6.3.6",
		"vite-plugin-electron": "0.28.8",
		"vite-plugin-electron-renderer": "0.14.6"
	},
	"main": "dist-electron/main.js",
	"homepage": "./"
}
