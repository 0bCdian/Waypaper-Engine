{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "electron/main.ts",
    "electron/preload.ts",
    "globals/setup.ts",
    "scripts/**/*.ts",
    "e2e/**/*.spec.ts",
    "docs/.vitepress/config.mts",
    "docs/.vitepress/theme/index.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "shared/**/*.ts",
    "electron/**/*.ts",
    "globals/**/*.ts",
    "scripts/**/*.ts"
  ],
  "ignore": ["electron/daemon-go-types.generated.ts"],
  "ignoreDependencies": [
    "ci",
    "@fontsource-variable/inter",
    "@fontsource-variable/space-grotesk",
    "@fontsource/aldrich",
    "@fontsource/google-sans",
    "@fontsource/google-sans-flex",
    "@fontsource/jetbrains-mono",
    "daisyui",
    "tailwindcss"
  ],
  "ignoreBinaries": ["go", "swag", "make"]
}
