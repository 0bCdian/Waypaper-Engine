// ❌ Mixing concerns, no proper structure
export default class Button extends React.Component {
  constructor(props) {
    super(props)
    this.state = { isHovered: false }
  }

  // ❌ Mixing UI and business logic
  handleClick() {
    if (this.props.disabled || !this.props.onClick) {
      return
    }

    // ❌ Direct API call in component
    fetch('/api/log', { method: 'POST' })
    this.props.onClick()
  }

  render() {
    // ❌ Not using optional chaining
    const label = this.props.label || 'Click me'

    return <Button onPress={this.handleClick.bind(this)}>{label}</Button>
  }
}
```

